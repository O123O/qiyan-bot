TELEGRAM_BOT_TOKEN=replace-with-botfather-token
TELEGRAM_OWNER_ID=123456789
TELEGRAM_DESTINATION_CHAT_ID=123456789
# Configure either the complete Telegram group above or all four Slack values below.
# WeChat credentials are managed by qiyan-bot weixin-login and must not be put in .env.
# When multiple adapters are present, set PRIMARY_CHAT_APP=telegram, slack, or weixin.
# SLACK_APP_TOKEN=xapp-replace
# SLACK_BOT_TOKEN=xoxb-replace
# SLACK_USER_TOKEN=xoxp-replace
# SLACK_OWNER_USER_ID=U01234567
# PRIMARY_CHAT_APP=weixin
CODEX_BINARY=codex
# Claude endpoints (local and remote) are configured in <qiyan_home>/endpoints.json, not here.
# Web UI default host/port. The web UI is off by default; turn it on with `qiyan-bot web-ui start`
# (persisted, no config flag). `start --host/--port` overrides these. A non-loopback WEB_HOST binds
# to the LAN — a danger-full-access surface over plain HTTP with a sniffable token (token still
# required); prefer 127.0.0.1 + an SSH tunnel.
# WEB_HOST=127.0.0.1
# WEB_PORT=9520
MAX_CONCURRENT_TURNS=4
MAX_COLLECT_COUNT=20
MCP_HOST=127.0.0.1
MCP_PORT=43721
ATTACHMENT_MAX_BYTES=20971520
ATTACHMENT_STORE_MAX_BYTES=1073741824
ASSISTANT_SANDBOX_MODE=danger-full-access
